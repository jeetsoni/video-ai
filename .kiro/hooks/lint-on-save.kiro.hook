{
  "name": "Lint TypeScript on Save",
  "version": "1.0.0",
  "description": "Automatically runs the project linter when any TypeScript or TSX file is saved, catching issues early in the development loop.",
  "when": {
    "type": "fileEdited",
    "patterns": ["**/*.ts", "**/*.tsx"]
  },
  "then": {
    "type": "runCommand",
    "command": "npx turbo lint"
  }
}