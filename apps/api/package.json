{
  "name": "@video-ai/api",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/shared/presentation/http/server.ts",
    "build": "tsc && npm run db:generate",
    "start": "node --import tsx/esm src/shared/presentation/http/server.ts",
    "lint": "tsc --noEmit",
    "clean": "rm -rf dist",
    "db:deploy": "prisma migrate deploy",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:push": "prisma db push",
    "db:studio": "prisma studio",
    "db:seed": "tsx src/pipeline/infrastructure/seed/seed-themes.ts",
    "test": "NODE_OPTIONS='--experimental-vm-modules' jest --passWithNoTests",
    "test:coverage": "NODE_OPTIONS='--experimental-vm-modules' jest --coverage --passWithNoTests"
  },
  "dependencies": {
    "@ai-sdk/google": "^3.0.64",
    "@ai-sdk/openai": "^3.0.53",
    "@aws-sdk/client-s3": "^3.1031.0",
    "@aws-sdk/s3-request-presigner": "^3.1031.0",
    "@elevenlabs/elevenlabs-js": "^2.43.0",
    "@prisma/client": "^6.9.0",
    "@remotion/bundler": "4.0.448",
    "@remotion/google-fonts": "4.0.448",
    "@remotion/renderer": "4.0.448",
    "@video-ai/shared": "*",
    "ai": "^6.0.168",
    "bullmq": "^5.74.1",
    "dotenv": "^17.4.2",
    "express": "^5.1.0",
    "ioredis": "^5.10.1",
    "remotion": "4.0.448",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/jest": "^29.5.0",
    "@types/node": "^22.0.0",
    "fast-check": "^3.22.0",
    "jest": "^29.7.0",
    "prisma": "^6.9.0",
    "ts-jest": "^29.2.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
}
