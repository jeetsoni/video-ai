# ─── Database ───
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/video_ai

# ─── Redis ───
REDIS_URL=redis://localhost:6379

# ─── Object Storage (S3-compatible) ───
# Local dev: MinIO (localhost:9000, minioadmin/minioadmin)
# Production: Cloudflare R2 (<account-id>.r2.cloudflarestorage.com, port 443, SSL true)
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=video-ai
MINIO_USE_SSL=false

# ─── API ───
API_PORT=4000
API_URL=http://localhost:4000

# ─── Frontend ───
# In production, set this to your deployed API URL (e.g. https://api.yourapp.railway.app)
NEXT_PUBLIC_API_URL=http://localhost:4000

# ─── AI Services ───
OPENAI_API_KEY=sk-your-openai-api-key
GEMINI_API_KEY=your-gemini-api-key
ELEVENLABS_API_KEY=your-elevenlabs-api-key
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM
